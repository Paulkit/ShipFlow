APP_NAME=ShipFlow
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080
APP_PORT=8080

# ── Database (local Docker → swap for RDS in production) ──
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=shipflow
DB_USERNAME=root
DB_PASSWORD=secret

# ── Queue (redis locally → swap for sqs in production) ──
QUEUE_CONNECTION=redis
REDIS_HOST=redis
REDIS_PORT=6379

# ── File Storage (local → swap for s3 in production) ──
FILESYSTEM_DISK=local

# ── Mail (log locally → swap for ses/mailgun in production) ──
MAIL_MAILER=log
CACHE_STORE=file
SESSION_DRIVER=file

# ── AWS (leave blank locally — only needed for production) ──
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-east-1
AWS_BUCKET=shipflow-invoices
SQS_PREFIX=https://sqs.ap-east-1.amazonaws.com/your-account-id
SQS_QUEUE=shipflow-jobs

# ── Filament Admin ──
FILAMENT_ADMIN_EMAIL=admin@shipflow.test
FILAMENT_ADMIN_PASSWORD=password
